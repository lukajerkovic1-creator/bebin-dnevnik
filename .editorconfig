root = true

[*.{kt,kts}]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4

# Ktlint bez semantičke analize pogrešno tumači pozive Compose funkcija i konstruktora kao deklaracije.
# Ispravnost naziva deklaracija i duljinu redaka provjerava Detekt s Compose-aware konfiguracijom.
ktlint_standard_function-naming = disabled
ktlint_standard_max-line-length = disabled
